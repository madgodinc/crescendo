# Crescendo configuration — copy to .env and fill in your own keys.
#
#   cp .env.example .env
#
# The DASHBOARD and the BRAIN run with no keys (docker compose up shows a
# recorded run). You only need the keys below to run the LIVE orchestra
# (agents.py + maestro.py): your own Band agents, an LLM provider, and a
# Cloudflare account to deploy to. We give you the engine; you bring the fuel.

# ── Brain (mgi-mind) ──────────────────────────────────────────────────────────
MGIMIND_URL=http://127.0.0.1:8765
MGIMIND_LIBRARY=crescendo
MGIMIND_STATE_LIBRARY=crescendo-state
# one bearer token per agent so every memory write is attributed (the audit trail)
MGIMIND_TOKEN_CONDUCTOR=crescendo_conductor_tok
MGIMIND_TOKEN_SOLOIST=crescendo_soloist_tok
MGIMIND_TOKEN_TUNING_FORK=crescendo_tuningfork_tok
MGIMIND_TOKEN_STAGE_TECH=crescendo_stagetech_tok
MGIMIND_TOKEN_ARCHIVIST=crescendo_archivist_tok

# ── Band (the multi-agent collaboration layer) ───────────────────────────────
# Create 5 agents in Band; paste each agent's UUID + API key, and the command room.
BAND_REST_URL=https://app.band.ai
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
MAESTRO_COMMAND_ROOM=
MAESTRO_AGENT_ID=
MAESTRO_API_KEY=
CONDUCTOR_AGENT_ID=
CONDUCTOR_API_KEY=
SOLOIST_AGENT_ID=
SOLOIST_API_KEY=
TUNING_FORK_AGENT_ID=
TUNING_FORK_API_KEY=
STAGE_TECH_AGENT_ID=
STAGE_TECH_API_KEY=
ARCHIVIST_AGENT_ID=
ARCHIVIST_API_KEY=

# ── LLM provider (the agents' brains) ────────────────────────────────────────
# Primary + fallback. Either provider's key is enough to run; both = resilient.
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_API_KEY=

# ── Deploy target (where the Stage Tech ships the page) ──────────────────────
# wrangler must be logged in to this Cloudflare account.
CF_PAGES_PROJECT=crescendo-demo
